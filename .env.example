# Snellius HPC credentials
# Copy this file to .env and fill in your details.
# .env is git-ignored and must NEVER be committed.

SNELLIUS_USER=your_username
SNELLIUS_HOST=snellius.surf.nl
SNELLIUS_PASS=your_password

# Optional: override default remote project directory
# SNELLIUS_PROJECT_DIR=$HOME/codes/students/surrogates
